            stems: { '甲': '树林', '乙': '草园', '丙': '亮灯', '丁': '灯光', '戊': '空地', '己': '小路', '庚': '大金属', '辛': '小金属', '壬': '大湖', '癸': '小水' },
            branches: { '子': '溪流', '丑': '池塘', '寅': '大林', '卯': '库房', '辰': '水库', '巳': '阳光', '午': '田园', '未': '草茂', '申': '机器', '酉': '珠宝', '戌': '大路', '亥': '深田' }
