    stripBaziJargon: function (text) {
        if (!text) return "";
        return text.replace(/【.*?】/g, '').replace(/\(.*?\)/g, '').replace(/（.*?）/g, '')
            .replace(/日主是/g, '命理五行属').replace(/日主/g, '你').replace(/日坐/g, '内心倾向于')
            .replace(/式的底色/g, '的性格底色').replace(/\n\n/g, ' ').replace(/、/g, '，').replace(/\s+/g, ' ').trim();
    },

    generateScript: function (report) {
        const cards = this.generateCards(report);
        return cards.map(c => c.content).join("\n\n");
    },

    generateCards: function (report) {
        if (!report || !report.bazi) return [{ title: "错误", content: "数据不足" }];
        const { bazi, wealth, marriage } = report;
        const pillars = bazi.pillars || [];
        const dm = pillars[2].gan;
        const dayZhi = pillars[2].zhi;
        let pText = this.data.dm[dm] || "";
        let dayBranchGod = null;
        if (dayZhi && window.HIDDEN_STEMS_MAP && window.HIDDEN_STEMS_MAP[dayZhi]) {
            const primaryStem = window.HIDDEN_STEMS_MAP[dayZhi][0];
            dayBranchGod = window.getTenGod ? window.getTenGod(dm, primaryStem) : null;
        }
        let innerText = (dayBranchGod && this.data.gods[dayBranchGod]) ? this.data.gods[dayBranchGod] : "";
        let problemDesc = "目前的磁场略显波折，需要耐心经营。";
        const wBad = wealth?.matchTerms?.some(t => t.type === 'bad');
        if (wBad) problemDesc = "财运方面面临一些阶段性挑战。";
        const rawEssay = `仔细观察命局，你初步印象是${pText} 深入内心，隐藏着${innerText} 的底色。近期${problemDesc} 这种运势起伏要求从心态上调整。`;
        return [{ title: "大师综断", content: this.stripBaziJargon(rawEssay), type: "synthesis" }];
    },

    generateScriptLibrary: function (report) {
        if (!report) return null;
        const pillars = report.pillars || (report.bazi ? report.bazi.pillars : null);
        if (!pillars) return null;

        const dm = pillars[2].gan;
        const bs = report.bodyStrength || (window.calculateBodyStrength ? window.calculateBodyStrength(pillars) : null);
        const prof = report.profile || (bs ? bs.profile : (window.getFiveElementProfile ? window.getFiveElementProfile(pillars) : null));

        const analysisData = { ...report, bodyStrength: bs, profile: prof };
        const dynLuck = (report.currentDaYun || report.selectedLiuNian) ? { daYun: report.currentDaYun, liuNian: report.selectedLiuNian } : null;

        const academic = report.academic || (window.calculateAcademicStatus ? window.calculateAcademicStatus(analysisData, [], dynLuck, report.expertData) : null);
        const wealth = report.wealth || (window.calculateWealthStatus ? window.calculateWealthStatus(analysisData, report.currentDaYun, report.expertData) : null);
        const marriage = report.marriage || (window.calculateMarriageStatus ? window.calculateMarriageStatus(analysisData, dynLuck, report.expertData) : null);

        const lib = {
            opening: [],
            impact: [],
            wealth: [],
            marriage: [],
            academic: [],
            career: [],
            sexlife: [],
            children: [],
            legal: [],
            fengshui: []
        };

        const ID_MAP = {
            'Wealth_Root': { Y: '身强', N: '身弱' },
            'Academic_Root': { Y: '开启学业诊断' },
            'A1_start': { Y: '进入身强求财逻辑' },
            'A1_hasW': { Y: '有财', N: '没财' },
            'A1_strongW': { Y: '财星旺相', N: '财星气弱' },
            'A1_S_Food': { Y: '食神生财', N: '财星无源头' },
            'A1_S_Seal': { Y: '印旺为忌' },
            'A1_S_Break': { Y: '财星坏印' },
            'A1_S_Officer': { Y: '官杀受制' },
            'A1_S_GenOff': { Y: '财旺生官' },
            'res_Sex_Enjoy': { Y: '乐享共鸣' },
            'res_Sex_Lustful': { Y: '激情旺盛' },
            'res_Sex_Frustrated': { Y: '能量卡点' },
            'res_Sex_Weak': { Y: '底子稍薄' },
            'res_Sex_Harmonious': { Y: '身心合一' },
            'res_Sex_Balanced': { Y: '节奏平稳' },
            'res_Sex_Restrained': { Y: '心态拘谨' },
            'res_Sex_Dominant': { Y: '掌控感强' },
            'res_Child_Prosperous': { Y: '子女缘深' },
            'res_Child_GoodEdu': { Y: '才俊后辈' },
            'res_Child_Stubborn': { Y: '性格鲜明' },
            'res_Child_Delayed': { Y: '缘分稍晚' },
            'res_Child_Weak缘': { Y: '缘分淡薄' },
            'res_Legal_Safe': { Y: '奉公守法' },
            'res_Legal_Resolved': { Y: '逢凶化吉' },
            'res_Legal_Dispute': { Y: '口舌是非' },
            'res_Legal_Severe': { Y: '法理警示' },
            'res_Legal_Economic': { Y: '经济纠纷' }
        };

        const TREE_TO_PATTERN = {
            'res_Elite': ['A_P_Elite_Stem', 'A_P_Elite_Output_Stem', 'A_P_Top_Tier'],
            'res_Disciplined': ['A_P_Foundation_Branch', 'A_P_Hardworking'],
            'res_A1_Ent': ['W_P_Entrepreneur', 'W_P_Rich_Noble']
        };

        // --- 1. Base Personality (Day Master & Inner Core) ---
        const dmDesc = this.data.dm[dm];
        if (dmDesc) {
            lib.opening.push({
                title: "日主本性",
                content: this.stripBaziJargon(dmDesc),
                pureContent: dmDesc
            });
        } else {
            // Fallback if dm is somehow not found
            lib.opening.push({
                title: "日主本性",
                content: "您的命主能量独特，展现出刚柔并济的特质。",
                pureContent: "您的命主能量独特，展现出刚柔并济的特质。"
            });
        }

        const dayZhi = pillars[2].zhi;
        let dayBranchGod = null;
        if (dayZhi && window.HIDDEN_STEMS_MAP && window.HIDDEN_STEMS_MAP[dayZhi]) {
            const primaryStem = window.HIDDEN_STEMS_MAP[dayZhi][0];
            dayBranchGod = window.getTenGod ? window.getTenGod(dm, primaryStem) : null;
            const innerDesc = (dayBranchGod && this.data.gods[dayBranchGod]) ? this.data.gods[dayBranchGod] : null;

            if (innerDesc) {
                lib.opening.push({
                    title: "内心底色",
                    content: `在您内心深处，隐藏着一种【${dayBranchGod}】的特质：${this.stripBaziJargon(innerDesc)}`,
                    pureContent: innerDesc
                });
            }
        }

        // --- 2. Interaction / Social Style (Ten God Lookup & Enhancement) ---
        // Calculate Ten God counts to find dominant energies
        const godCounts = {};
        const godNames = ['正官', '七杀', '正印', '偏印', '正财', '偏财', '伤官', '食神', '比肩', '劫财'];

        pillars.forEach(p => {
            const g = window.getTenGod ? window.getTenGod(dm, p.gan) : null;
            if (g && godNames.includes(g)) godCounts[g] = (godCounts[g] || 0) + 1;

            if (window.HIDDEN_STEMS_MAP && window.HIDDEN_STEMS_MAP[p.zhi]) {
                // Main Qi only for simplicity and strength
                const mainStem = window.HIDDEN_STEMS_MAP[p.zhi][0];
                const zg = window.getTenGod ? window.getTenGod(dm, mainStem) : null;
                if (zg && godNames.includes(zg)) godCounts[zg] = (godCounts[zg] || 0) + 1;
            }
        });

        // Sort gods by count
        const sortedGods = Object.entries(godCounts).sort((a, b) => b[1] - a[1]);
        const topGods = sortedGods.slice(0, 3).map(e => e[0]);

        // Add specific Ten God traits to "Inner" (Opening)
        topGods.forEach(god => {
            if (this.data.gods[god]) {
                lib.opening.push({
                    title: `性格侧写：${god}`,
                    content: this.stripBaziJargon(this.data.gods[god]),
                    pureContent: this.data.gods[god]
                });
            }
        });

        // --- Generate Unified "Inner" Essay ---
        if (topGods.length > 0) {
            let innerEssay = "";
            const dmText = this.data.dm[dm] ? this.stripBaziJargon(this.data.dm[dm]) : "";
            if (dmText) innerEssay += `    ${dmText}\n\n`;

            const godTraits = topGods.map(god => {
                const desc = this.data.gods[god] ? this.stripBaziJargon(this.data.gods[god]) : "";
                return desc ? `    【${god}】的影响：${desc}` : "";
            }).filter(t => t).join("\n\n");

            if (godTraits) innerEssay += `    此外，从命局能量分布来看，您深受以下几股力量的交织影响：\n\n${godTraits}`;

            // Remove purely DM card if it exists to avoid duplication, replacing it with the composite essay
            const existingDmIndex = lib.opening.findIndex(i => i.title === "日主本性");
            if (existingDmIndex !== -1) lib.opening.splice(existingDmIndex, 1);

            lib.opening.unshift({
                title: "大师综合性格剖析 (核心小作文)",
                content: innerEssay,
                pureContent: innerEssay
            });
        }

        // --- Generate Unified "Interaction" Essay ---
        if (topGods.length > 0) {
            let socialAdvantages = [];
            let socialRisks = [];

            topGods.forEach(god => {
                if (this.data.godsExpanded[god]) {
                    const traits = this.data.godsExpanded[god];
                    socialAdvantages.push(`【${god}】赋能：${traits.positive}`);
                    socialRisks.push(`需留意【${god}】负面：${traits.negative}`);
                }
            });

            if (socialAdvantages.length > 0 || socialRisks.length > 0) {
                const socialEssay = `    在人际交往与社会互动中，您的命局呈现出多面的特质。\n\n` +
                    (socialAdvantages.length > 0 ? `    🌟 **天赋优势**：\n    ${socialAdvantages.join('；')}\n\n` : "") +
                    (socialRisks.length > 0 ? `    ⚠️ **潜在风险**：\n    ${socialRisks.join('；')}` : "");

                lib.impact.push({
                    title: "社交互动风格综合画像",
                    content: socialEssay,
                    pureContent: socialEssay
                });
            }
        } else if (dm) {
            // Fallback to DM-based social style if no gods found (rare)
            let socialDesc = "";
            if (['甲', '乙'].includes(dm)) socialDesc = "与人交往如沐春风，注重仁义与情感交流，但也容易因心软而承担过多。";
            else if (['丙', '丁'].includes(dm)) socialDesc = "在人群中容易展现热情与礼貌，善于调动气氛，但有时也会过于在意他人的反馈。";
            else if (['戊', '己'].includes(dm)) socialDesc = "给人稳重可靠的感觉，信守承诺，包容力强，是朋友眼中值得信赖的伙伴。";
            else if (['庚', '辛'].includes(dm)) socialDesc = "行事果断，讲究原则与义气，在社交中爱憎分明，不喜欢拖泥带水。";
            else if (['壬', '癸'].includes(dm)) socialDesc = "灵活多变，适应力强，善于在复杂的社交环境中游刃有余，充满智慧。";

            lib.impact.push({
                title: "社交互动风格",
                content: socialDesc,
                pureContent: socialDesc
            });
        }

        if (report.expertData && report.expertData.decisionResult) {
            const dtData = report.expertData.decisionResult;
            const results = dtData.results || [];
            const trace = dtData.trace || [];
            const partnerAttributes = [];

            results.forEach((res) => {
                const resId = res.id;
                let targetCat = 'wealth';

                if (resId.startsWith('res_Career')) targetCat = 'career';
                else if (resId.startsWith('res_Sex')) targetCat = 'sexlife';
                else if (resId.startsWith('res_Child')) targetCat = 'children';
                else if (resId.startsWith('res_Legal')) targetCat = 'legal';
                else if (resId.startsWith('res_Rel') || resId.startsWith('res_Time') || resId.startsWith('res_Trait') || resId.startsWith('res_App')) targetCat = 'marriage';
                else if (resId.startsWith('res_Elite') || resId.includes('academic')) targetCat = 'academic';
                else if (resId.startsWith('res_Char') || resId.startsWith('res_Inner')) targetCat = 'opening';
                else if (resId.startsWith('res_Social') || resId.startsWith('res_Interaction')) targetCat = 'impact';

                const chain = [];
                trace.forEach(step => {
                    const map = ID_MAP[step.id];
                    if (map) {
                        const label = step.decision ? map.Y : map.N;
                        if (label) chain.push(label);
                    }
                });
                const pathStr = [...new Set(chain)].join(' -> ');

                let finalNarrative = res.desc;
                const mappedPatternIds = TREE_TO_PATTERN[res.id] || [];
                const pResults = (report.expertData && report.expertData.patternResults) || report.patternResults || [];
                const pattern = pResults.find(p => mappedPatternIds.includes(p.id));
                if (pattern) finalNarrative = pattern.narrative || pattern.desc;

                if (resId.startsWith('res_Trait') || resId.startsWith('res_App')) {
                    partnerAttributes.push({ text: finalNarrative, tags: res.tags || (pattern ? pattern.tags : []), path: pathStr });
                    return;
                }

                if (lib[targetCat]) {
                    const cleanNarrative = this.stripBaziJargon(finalNarrative);
                    lib[targetCat].unshift({
                        title: `🔮 大师终极定论: ${res.title}`,
                        content: `${cleanNarrative}\n\n> [!NOTE]\n> **逻辑溯源**：${pathStr || '综合判定'}`,
                        pureContent: cleanNarrative,
                        tags: res.tags || (pattern ? pattern.tags : [])
                    });
                }
            });

            if (partnerAttributes.length > 0) {
                const combinedText = partnerAttributes.map(p => p.text).join('\n\n');
                lib.marriage.unshift({
                    title: "🔮 大师终极定论: 另一半画像 (综合)",
                    content: `${combinedText}\n\n> [!NOTE]\n> **定论溯源**：${partnerAttributes.map(p => p.path).filter(p => p).join(' + ')}`,
                    pureContent: combinedText,
                    tags: [...new Set(partnerAttributes.flatMap(p => p.tags))]
                });
            }
        }

        if (lib.wealth.length === 0) lib.wealth.push({ title: "无明显财运断语", content: "暂无特定财运断语。" });
        if (lib.marriage.length === 0) lib.marriage.push({ title: "无明显婚姻断语", content: "暂无特定婚姻断语。" });

        // Feng Shui core
        const fsEnvironment = this.generateFengShuiAnalysis(pillars);
        fsEnvironment.forEach(item => {
            lib.fengshui.push({ title: item.title, content: item.content, pureContent: item.content });
        });

        return lib;
    },

    generateHoroscopeNarrative(lib) {
        let story = "";
        if (lib.opening?.length > 0) story += "### 🌟 能量底色\n" + lib.opening.map(i => i.content).join("\n\n") + "\n\n";
        if (lib.fengshui?.length > 0) story += "### 🔮 趋吉避凶\n" + lib.fengshui.map(i => i.content).join("\n\n") + "\n\n";
        return story || "正在汇聚能量中...";
    },

    generateUnifiedPersonalityEssay(dm, dayZhi, godStrengths) {
        return `作为${dm}命的人，性格独特。`;
    },

    /**
     * Generate Feng Shui environment analysis based on pillar spatial mapping.
     * Maps pillars to house directions (Traditional South-on-Top).
     * Includes logical housing conclusions based on Seal Stars (Zheng Yin / Pian Yin).
     */
    generateFengShuiAnalysis(pillars) {
        if (!pillars || pillars.length < 4) return [];
        const res = [];
        const fs = this.data.fengshuiEnv;
        if (!fs) return [];

        const dm = pillars[2].gan;
        let zhengYinCount = 0;
        let pianYinCount = 0;
        let zhengYinToured = false;

        // 1. Scan for Seal Stars
        pillars.forEach((p, idx) => {
            const gGod = window.getTenGod ? window.getTenGod(dm, p.gan) : null;
            if (gGod === '正印') { zhengYinCount++; zhengYinToured = true; }
            if (gGod === '偏印') { pianYinCount++; }
            if (window.HIDDEN_STEMS_MAP && window.HIDDEN_STEMS_MAP[p.zhi]) {
                window.HIDDEN_STEMS_MAP[p.zhi].forEach(s => {
                    const zGod = window.getTenGod ? window.getTenGod(dm, s) : null;
                    if (zGod === '正印') zhengYinCount++;
                    if (zGod === '偏印') pianYinCount++;
                });
            }
        });

        // 2. Draft Housing Conclusions
        let housingConclusion = "";
        if (zhengYinCount > 0 && pianYinCount > 0) {
            housingConclusion = "命中正偏印俱见，混杂交织。表示命主一生喜出门在外，走动较多，经常搬家。居住过的地方很多，且往往是因为工作或环境变化而频繁迁移。";
        } else if (zhengYinCount > 0 && pianYinCount === 0) {
            housingConclusion = zhengYinToured
                ? "命中带纯正印且天干透出，多主居住的是国家分配之官房、公房或单位福利房，自己拥有长期稳定的居住权。"
                : "命中带纯正印且藏于地支，主居住的是祖辈留下的产业或有稳固产权的房子，环境稳固扎实。";
        } else if (pianYinCount > 0 && zhengYinCount === 0) {
            housingConclusion = "命中无正印而只有偏印（以偏当正），主居住的通常不是祖辈之房。往往在父辈时就已经迁居，或者您本人也经常搬迁，属于典型的变动型居住规律。";
        }

        if (housingConclusion) {
            res.push({ title: "🔮 大师定论：居住与房产特征", content: housingConclusion });
        }

        // 3. Mapping (Traditional South-on-Top): Year->SW, Month->SE, Day->NW, Hour->NE
        const directions = [
            '【西南方】 (坤位)', '【东南方】 (巽位)', '【西北方】 (乾位)', '【东北方】 (艮位)'
        ];

        pillars.forEach((p, i) => {
            const dir = directions[i];
            const gDetail = fs.stems[p.gan];
            const zDetail = fs.branches[p.zhi];
            if (gDetail || zDetail) {
                let content = `从房屋中心点看去，在${dir}：`;
                if (gDetail) content += `天干能量映射为“${gDetail}”；`;
                if (zDetail) content += `地物能量映射为“${zDetail}”。`;
                res.push({ title: `房屋${dir} 气场特征`, content: content });
            }
        });

        res.push({
            title: "风水观测说明",
            content: "以上内容是根据您的命局空间分布反推的居住环境耦合点。方位映射遵循：年->西南，月->东南，日->西北，时->东北。"
        });

        return res;
    }
};

window.BaziNarrative = BaziNarrative;
